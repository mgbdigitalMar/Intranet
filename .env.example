APP_NAME="Intranet"
APP_ENV="production"
APP_KEY=base64:... # php artisan key:generate --show
APP_DEBUG="false"
APP_URL="https://intranet-production.up.railway.app" # tu URL

DB_CONNECTION="sqlite"
